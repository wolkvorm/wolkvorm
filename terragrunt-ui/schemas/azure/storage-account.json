{
  "id": "azure-storage",
  "name": "Storage Account",
  "description": "Azure Storage Account for Blob, File, Queue, and Table storage",
  "provider": "azurerm",
  "icon": "storage",
  "category": "storage",
  "inputs": [
    {
      "name": "name",
      "label": "Storage Account Name",
      "type": "string",
      "required": true,
      "placeholder": "mystorageaccount",
      "description": "Globally unique, 3-24 chars, lowercase letters and numbers only"
    },
    {
      "name": "resource_group_name",
      "label": "Resource Group",
      "type": "string",
      "required": true,
      "placeholder": "my-resource-group"
    },
    {
      "name": "location",
      "label": "Location",
      "type": "select",
      "required": true,
      "options": [
        "westeurope",
        "northeurope",
        "eastus",
        "eastus2",
        "westus2",
        "centralus",
        "southeastasia",
        "eastasia",
        "japaneast",
        "australiaeast",
        "uksouth"
      ],
      "default": "westeurope"
    },
    {
      "name": "account_tier",
      "label": "Account Tier",
      "type": "select",
      "required": true,
      "options": [
        "Standard",
        "Premium"
      ],
      "default": "Standard"
    },
    {
      "name": "account_replication_type",
      "label": "Replication Type",
      "type": "select",
      "required": true,
      "options": [
        "LRS",
        "GRS",
        "RAGRS",
        "ZRS",
        "GZRS",
        "RAGZRS"
      ],
      "default": "LRS",
      "description": "LRS = locally redundant, GRS = geo-redundant, ZRS = zone-redundant"
    },
    {
      "name": "account_kind",
      "label": "Account Kind",
      "type": "select",
      "required": false,
      "options": [
        "StorageV2",
        "Storage",
        "BlobStorage",
        "BlockBlobStorage",
        "FileStorage"
      ],
      "default": "StorageV2",
      "advanced": true
    },
    {
      "name": "access_tier",
      "label": "Access Tier",
      "type": "select",
      "required": false,
      "options": [
        "Hot",
        "Cool"
      ],
      "default": "Hot",
      "advanced": true
    },
    {
      "name": "enable_https_traffic_only",
      "label": "HTTPS Only",
      "type": "boolean",
      "required": false,
      "default": true
    },
    {
      "name": "min_tls_version",
      "label": "Min TLS Version",
      "type": "select",
      "required": false,
      "options": [
        "TLS1_0",
        "TLS1_1",
        "TLS1_2"
      ],
      "default": "TLS1_2",
      "advanced": true
    },
    {
      "name": "allow_nested_items_to_be_public",
      "label": "Allow Public Blob Access",
      "type": "boolean",
      "required": false,
      "default": false,
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/azure-storage-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//azure/storage-account?ref=main"
  }
}

{
  "id": "huawei-vpc",
  "name": "VPC",
  "description": "Huawei Cloud Virtual Private Cloud network",
  "provider": "huaweicloud",
  "icon": "vpc",
  "category": "networking",
  "inputs": [
    {
      "name": "name",
      "label": "VPC Name",
      "type": "string",
      "required": true,
      "placeholder": "my-vpc"
    },
    {
      "name": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "options": [
        "cn-north-4",
        "cn-east-3",
        "cn-south-1",
        "ap-southeast-1",
        "ap-southeast-2",
        "ap-southeast-3",
        "eu-west-101",
        "la-south-2"
      ],
      "default": "ap-southeast-1"
    },
    {
      "name": "cidr",
      "label": "CIDR Block",
      "type": "string",
      "required": true,
      "placeholder": "10.0.0.0/16",
      "default": "10.0.0.0/16"
    },
    {
      "name": "description",
      "label": "Description",
      "type": "string",
      "required": false,
      "placeholder": "VPC for my project",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/huawei-vpc-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terraform-modules/huawei/vpc?ref=main"
  }
}

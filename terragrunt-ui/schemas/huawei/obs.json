{
  "id": "huawei-obs",
  "name": "Object Storage (OBS)",
  "description": "Huawei Cloud Object Storage Service bucket",
  "provider": "huaweicloud",
  "icon": "storage",
  "category": "storage",
  "inputs": [
    {
      "name": "bucket",
      "label": "Bucket Name",
      "type": "string",
      "required": true,
      "placeholder": "my-obs-bucket",
      "description": "Globally unique bucket name"
    },
    {
      "name": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "options": [
        "cn-north-4",
        "cn-east-3",
        "cn-south-1",
        "ap-southeast-1",
        "ap-southeast-2",
        "ap-southeast-3",
        "eu-west-101",
        "la-south-2"
      ],
      "default": "ap-southeast-1"
    },
    {
      "name": "acl",
      "label": "ACL",
      "type": "select",
      "required": false,
      "options": [
        "private",
        "public-read",
        "public-read-write",
        "log-delivery-write"
      ],
      "default": "private"
    },
    {
      "name": "storage_class",
      "label": "Storage Class",
      "type": "select",
      "required": false,
      "options": [
        "STANDARD",
        "WARM",
        "COLD"
      ],
      "default": "STANDARD"
    },
    {
      "name": "versioning",
      "label": "Enable Versioning",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "encryption",
      "label": "Enable Encryption",
      "type": "boolean",
      "required": false,
      "default": false,
      "advanced": true
    },
    {
      "name": "force_destroy",
      "label": "Force Destroy",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Allow deletion of non-empty bucket",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/huawei-obs-{bucket}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terragrunt-ui/modules/huawei/obs?ref=main"
  }
}

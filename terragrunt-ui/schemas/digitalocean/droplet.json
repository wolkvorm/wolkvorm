{
  "id": "do-droplet",
  "name": "Droplet",
  "description": "DigitalOcean virtual machine (Droplet)",
  "provider": "digitalocean",
  "icon": "droplet",
  "category": "compute",
  "inputs": [
    {
      "name": "name",
      "label": "Droplet Name",
      "type": "string",
      "required": true,
      "placeholder": "my-droplet"
    },
    {
      "name": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "options": [
        "ams3",
        "fra1",
        "lon1",
        "nyc1",
        "nyc3",
        "sfo3",
        "sgp1",
        "tor1",
        "blr1",
        "syd1"
      ],
      "default": "ams3"
    },
    {
      "name": "size",
      "label": "Size",
      "type": "select",
      "required": true,
      "options": [
        "s-1vcpu-1gb",
        "s-1vcpu-2gb",
        "s-2vcpu-2gb",
        "s-2vcpu-4gb",
        "s-4vcpu-8gb",
        "s-8vcpu-16gb",
        "c-2",
        "c-4",
        "m-2vcpu-16gb",
        "g-2vcpu-8gb"
      ],
      "default": "s-2vcpu-2gb"
    },
    {
      "name": "image",
      "label": "Image",
      "type": "select",
      "required": true,
      "options": [
        "ubuntu-24-04-x64",
        "ubuntu-22-04-x64",
        "debian-12-x64",
        "debian-11-x64",
        "centos-stream-9-x64",
        "fedora-40-x64",
        "rockylinux-9-x64"
      ],
      "default": "ubuntu-24-04-x64"
    },
    {
      "name": "backups",
      "label": "Enable Backups",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "monitoring",
      "label": "Enable Monitoring",
      "type": "boolean",
      "required": false,
      "default": true
    },
    {
      "name": "ipv6",
      "label": "Enable IPv6",
      "type": "boolean",
      "required": false,
      "default": false,
      "advanced": true
    },
    {
      "name": "ssh_keys",
      "label": "SSH Key IDs",
      "type": "string",
      "required": false,
      "placeholder": "12345678, 87654321",
      "description": "Comma-separated DigitalOcean SSH key IDs or fingerprints",
      "advanced": true
    },
    {
      "name": "user_data",
      "label": "User Data (cloud-init)",
      "type": "multiline",
      "required": false,
      "placeholder": "#!/bin/bash\napt-get update",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/do-droplet-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terragrunt-ui/modules/digitalocean/droplet?ref=main"
  }
}

{
  "id": "do-spaces",
  "name": "Spaces Bucket",
  "description": "DigitalOcean Spaces S3-compatible object storage bucket",
  "provider": "digitalocean",
  "icon": "storage",
  "category": "storage",
  "inputs": [
    {
      "name": "name",
      "label": "Bucket Name",
      "type": "string",
      "required": true,
      "placeholder": "my-spaces-bucket",
      "description": "Globally unique bucket name"
    },
    {
      "name": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "options": [
        "ams3",
        "fra1",
        "lon1",
        "nyc3",
        "sfo3",
        "sgp1",
        "syd1"
      ],
      "default": "ams3"
    },
    {
      "name": "acl",
      "label": "ACL",
      "type": "select",
      "required": false,
      "options": [
        "private",
        "public-read"
      ],
      "default": "private"
    },
    {
      "name": "versioning_enabled",
      "label": "Enable Versioning",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "force_destroy",
      "label": "Force Destroy",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Allow deletion of non-empty bucket",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": false
  },
  "path_template": "infra/{env}/do-spaces-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//digitalocean/spaces?ref=main"
  }
}

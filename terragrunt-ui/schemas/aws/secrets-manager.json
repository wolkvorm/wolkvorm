{
  "id": "secrets-manager",
  "name": "Secrets Manager",
  "description": "AWS Secrets Manager for storing and rotating secrets",
  "provider": "aws",
  "icon": "secrets",
  "category": "security",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//aws/secrets-manager?ref=main"
  },
  "inputs": [
    {
      "name": "name",
      "label": "Secret Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app/database-password",
      "description": "Name/path of the secret"
    },
    {
      "name": "description",
      "label": "Description",
      "type": "string",
      "placeholder": "Database credentials for my-app",
      "description": "Description of the secret"
    },
    {
      "name": "recovery_window_in_days",
      "label": "Recovery Window (days)",
      "type": "number",
      "default": 30,
      "description": "Days before permanent deletion (0 for immediate)"
    },
    {
      "name": "secret_string",
      "label": "Secret Value",
      "type": "string",
      "placeholder": "my-secret-value",
      "description": "The secret value (stored encrypted)"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/secret-{name}/main.tf"
}

{
  "id": "iam-role",
  "name": "IAM Role",
  "description": "AWS IAM Role for service and cross-account access",
  "provider": "aws",
  "icon": "iam",
  "category": "security",
  "module": {
    "source": "git::https://github.com/terraform-aws-modules/terraform-aws-iam.git//modules/iam-assumable-role?ref=v5.37.0"
  },
  "inputs": [
    {
      "name": "role_name",
      "label": "Role Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app-role",
      "description": "Name of the IAM role"
    },
    {
      "name": "trusted_role_services",
      "label": "Trusted Services",
      "type": "string",
      "default": "ec2.amazonaws.com",
      "placeholder": "ec2.amazonaws.com,lambda.amazonaws.com",
      "description": "Comma-separated AWS services that can assume this role"
    },
    {
      "name": "custom_role_policy_arns",
      "label": "Policy ARNs",
      "type": "multiline",
      "placeholder": "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess\narn:aws:iam::aws:policy/CloudWatchLogsFullAccess",
      "description": "One policy ARN per line to attach to this role"
    },
    {
      "name": "role_requires_mfa",
      "label": "Require MFA",
      "type": "boolean",
      "default": false,
      "description": "Whether the role requires MFA"
    },
    {
      "name": "create_instance_profile",
      "label": "Instance Profile",
      "type": "boolean",
      "default": false,
      "description": "Create an instance profile for EC2"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/iam-{role_name}/terragrunt.hcl"
}

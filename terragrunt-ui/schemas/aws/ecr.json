{
  "id": "ecr",
  "name": "ECR Repository",
  "description": "Amazon Elastic Container Registry for Docker images",
  "provider": "aws",
  "icon": "ecr",
  "category": "compute",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terraform-modules/aws/ecr?ref=main"
  },
  "inputs": [
    {
      "name": "repository_name",
      "label": "Repository Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app",
      "description": "Name of the ECR repository"
    },
    {
      "name": "repository_type",
      "label": "Repository Type",
      "type": "select",
      "default": "private",
      "options": [
        "private",
        "public"
      ],
      "description": "Type of repository (private or public)"
    },
    {
      "name": "repository_image_tag_mutability",
      "label": "Tag Mutability",
      "type": "select",
      "default": "IMMUTABLE",
      "options": [
        "IMMUTABLE",
        "MUTABLE"
      ],
      "description": "Image tag mutability setting"
    },
    {
      "name": "repository_image_scan_on_push",
      "label": "Scan on Push",
      "type": "boolean",
      "default": true,
      "description": "Enable image vulnerability scanning on push"
    },
    {
      "name": "repository_encryption_type",
      "label": "Encryption",
      "type": "select",
      "default": "AES256",
      "options": [
        "AES256",
        "KMS"
      ],
      "description": "Encryption type for the repository"
    },
    {
      "name": "repository_force_delete",
      "label": "Force Delete",
      "type": "boolean",
      "default": false,
      "description": "Allow deletion even with images present"
    },
    {
      "name": "attach_repository_policy",
      "label": "Attach Repository Policy",
      "type": "boolean",
      "default": false,
      "description": "Attach an access policy to the repository",
      "advanced": true
    },
    {
      "name": "create_repository_policy",
      "label": "Create Repository Policy",
      "type": "boolean",
      "default": false,
      "description": "Create a repository access policy",
      "advanced": true
    },
    {
      "name": "create_lifecycle_policy",
      "label": "Create Lifecycle Policy",
      "type": "boolean",
      "default": false,
      "description": "Create a lifecycle policy for automatic image cleanup",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/ecr-{repository_name}/main.tf"
}

{
  "id": "alb",
  "name": "Application Load Balancer",
  "description": "AWS Application Load Balancer for HTTP/HTTPS traffic distribution",
  "provider": "aws",
  "icon": "alb",
  "category": "networking",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//aws/alb?ref=main"
  },
  "inputs": [
    {
      "name": "name",
      "label": "ALB Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app-alb",
      "description": "Name of the Application Load Balancer"
    },
    {
      "name": "vpc_id",
      "label": "VPC ID",
      "type": "string",
      "required": true,
      "placeholder": "vpc-0123456789abcdef0",
      "description": "VPC ID for the ALB",
      "aws_resource": "vpc"
    },
    {
      "name": "subnets",
      "label": "Subnet IDs",
      "type": "string",
      "required": true,
      "placeholder": "subnet-abc123,subnet-def456",
      "description": "Comma-separated public subnet IDs",
      "aws_resource": "subnet",
      "multi": true
    },
    {
      "name": "internal",
      "label": "Internal ALB",
      "type": "boolean",
      "default": false,
      "description": "If true, ALB will be internal (not internet-facing)"
    },
    {
      "name": "enable_deletion_protection",
      "label": "Deletion Protection",
      "type": "boolean",
      "default": false,
      "description": "Prevent accidental deletion"
    },
    {
      "name": "idle_timeout",
      "label": "Idle Timeout (seconds)",
      "type": "number",
      "default": 60,
      "description": "Time in seconds that the connection is allowed to be idle"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/alb-{name}/main.tf"
}

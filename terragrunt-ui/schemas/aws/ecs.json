{
  "id": "ecs",
  "name": "ECS Cluster",
  "description": "Amazon Elastic Container Service cluster for running containers",
  "provider": "aws",
  "icon": "ecs",
  "category": "compute",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terraform-modules/aws/ecs?ref=main"
  },
  "inputs": [
    {
      "name": "cluster_name",
      "label": "Cluster Name",
      "type": "string",
      "required": true,
      "placeholder": "my-ecs-cluster",
      "description": "Name of the ECS cluster"
    },
    {
      "name": "fargate_capacity_providers_enabled",
      "label": "Fargate Enabled",
      "type": "boolean",
      "default": true,
      "description": "Enable Fargate capacity provider"
    },
    {
      "name": "container_insights",
      "label": "Container Insights",
      "type": "boolean",
      "default": true,
      "description": "Enable CloudWatch Container Insights"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/ecs-{cluster_name}/main.tf"
}

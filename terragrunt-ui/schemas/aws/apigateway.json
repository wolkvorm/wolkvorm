{
  "id": "apigateway",
  "name": "API Gateway",
  "description": "Amazon API Gateway v2 (HTTP/WebSocket API)",
  "provider": "aws",
  "icon": "apigateway",
  "category": "networking",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//terraform-modules/aws/apigateway?ref=main"
  },
  "inputs": [
    {
      "name": "name",
      "label": "API Name",
      "type": "string",
      "required": true,
      "placeholder": "my-http-api",
      "description": "Name of the API Gateway"
    },
    {
      "name": "protocol_type",
      "label": "Protocol",
      "type": "select",
      "default": "HTTP",
      "options": [
        "HTTP",
        "WEBSOCKET"
      ],
      "description": "API protocol type"
    },
    {
      "name": "description",
      "label": "Description",
      "type": "string",
      "placeholder": "My HTTP API",
      "description": "Description of the API"
    },
    {
      "name": "cors_allow_origins",
      "label": "CORS Origins",
      "type": "string",
      "default": "*",
      "placeholder": "https://example.com",
      "description": "Allowed CORS origins (comma-separated)"
    },
    {
      "name": "cors_allow_methods",
      "label": "CORS Methods",
      "type": "string",
      "default": "GET,POST,PUT,DELETE,OPTIONS",
      "description": "Allowed CORS methods (comma-separated)"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/apigw-{name}/main.tf"
}

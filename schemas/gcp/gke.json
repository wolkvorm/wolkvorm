{
  "id": "gcp-gke",
  "name": "GKE Cluster",
  "description": "Google Kubernetes Engine managed Kubernetes cluster",
  "provider": "google",
  "icon": "gke",
  "category": "containers",
  "inputs": [
    {
      "name": "name",
      "label": "Cluster Name",
      "type": "string",
      "required": true,
      "placeholder": "my-gke-cluster"
    },
    {
      "name": "project",
      "label": "Project ID",
      "type": "string",
      "required": true,
      "placeholder": "my-gcp-project"
    },
    {
      "name": "location",
      "label": "Location (Region/Zone)",
      "type": "select",
      "required": true,
      "options": [
        "europe-west1",
        "europe-west1-b",
        "europe-west4",
        "us-central1",
        "us-central1-a",
        "us-east1",
        "us-west1",
        "asia-east1",
        "asia-northeast1",
        "australia-southeast1"
      ],
      "default": "europe-west1",
      "description": "Use a region for regional cluster, zone for zonal cluster"
    },
    {
      "name": "min_master_version",
      "label": "Min Kubernetes Version",
      "type": "string",
      "required": false,
      "placeholder": "1.31",
      "default": "latest"
    },
    {
      "name": "remove_default_node_pool",
      "label": "Remove Default Node Pool",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "Recommended: remove default pool and manage node pools separately",
      "advanced": true
    },
    {
      "name": "initial_node_count",
      "label": "Initial Node Count",
      "type": "number",
      "required": false,
      "default": 1,
      "description": "Required even if remove_default_node_pool is true",
      "advanced": true
    },
    {
      "name": "network",
      "label": "Network",
      "type": "string",
      "required": false,
      "placeholder": "default",
      "default": "default"
    },
    {
      "name": "subnetwork",
      "label": "Subnetwork",
      "type": "string",
      "required": false,
      "placeholder": "default",
      "advanced": true
    },
    {
      "name": "networking_mode",
      "label": "Networking Mode",
      "type": "select",
      "required": false,
      "options": [
        "VPC_NATIVE",
        "ROUTES"
      ],
      "default": "VPC_NATIVE",
      "advanced": true
    },
    {
      "name": "deletion_protection",
      "label": "Deletion Protection",
      "type": "boolean",
      "required": false,
      "default": false,
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": false
  },
  "path_template": "infra/{env}/gcp-gke-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/gcp/gke?ref=main"
  }
}

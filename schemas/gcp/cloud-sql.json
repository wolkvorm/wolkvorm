{
  "id": "gcp-cloudsql",
  "name": "Cloud SQL Instance",
  "description": "Google Cloud SQL managed relational database (PostgreSQL / MySQL)",
  "provider": "google",
  "icon": "database",
  "category": "database",
  "inputs": [
    {
      "name": "name",
      "label": "Instance Name",
      "type": "string",
      "required": true,
      "placeholder": "my-sql-instance",
      "description": "Globally unique Cloud SQL instance name"
    },
    {
      "name": "project",
      "label": "Project ID",
      "type": "string",
      "required": true,
      "placeholder": "my-gcp-project"
    },
    {
      "name": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "options": [
        "europe-west1",
        "europe-west4",
        "us-central1",
        "us-east1",
        "us-west1",
        "asia-east1",
        "asia-northeast1",
        "australia-southeast1"
      ],
      "default": "europe-west1"
    },
    {
      "name": "database_version",
      "label": "Database Version",
      "type": "select",
      "required": true,
      "options": [
        "POSTGRES_16",
        "POSTGRES_15",
        "POSTGRES_14",
        "POSTGRES_13",
        "MYSQL_8_0",
        "MYSQL_8_4"
      ],
      "default": "POSTGRES_16"
    },
    {
      "name": "tier",
      "label": "Machine Tier",
      "type": "select",
      "required": false,
      "options": [
        "db-f1-micro",
        "db-g1-small",
        "db-n1-standard-1",
        "db-n1-standard-2",
        "db-n1-standard-4",
        "db-custom-2-7680",
        "db-custom-4-15360"
      ],
      "default": "db-n1-standard-2"
    },
    {
      "name": "disk_size",
      "label": "Disk Size (GB)",
      "type": "number",
      "required": false,
      "default": 20
    },
    {
      "name": "disk_autoresize",
      "label": "Auto Resize Disk",
      "type": "boolean",
      "required": false,
      "default": true,
      "advanced": true
    },
    {
      "name": "availability_type",
      "label": "Availability Type",
      "type": "select",
      "required": false,
      "options": [
        "ZONAL",
        "REGIONAL"
      ],
      "default": "ZONAL",
      "description": "REGIONAL = high availability with failover",
      "advanced": true
    },
    {
      "name": "deletion_protection",
      "label": "Deletion Protection",
      "type": "boolean",
      "required": false,
      "default": true,
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": false
  },
  "path_template": "infra/{env}/gcp-cloudsql-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/gcp/cloud-sql?ref=main"
  }
}

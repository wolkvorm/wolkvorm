{
  "id": "azure-vm",
  "name": "Linux Virtual Machine",
  "description": "Azure Linux Virtual Machine instance",
  "provider": "azurerm",
  "icon": "vm",
  "category": "compute",
  "inputs": [
    {
      "name": "name",
      "label": "VM Name",
      "type": "string",
      "required": true,
      "placeholder": "my-vm"
    },
    {
      "name": "resource_group_name",
      "label": "Resource Group",
      "type": "string",
      "required": true,
      "placeholder": "my-resource-group"
    },
    {
      "name": "location",
      "label": "Location",
      "type": "select",
      "required": true,
      "options": [
        "westeurope",
        "northeurope",
        "eastus",
        "eastus2",
        "westus2",
        "centralus",
        "southeastasia",
        "eastasia",
        "japaneast",
        "australiaeast",
        "uksouth"
      ],
      "default": "westeurope"
    },
    {
      "name": "size",
      "label": "VM Size",
      "type": "select",
      "required": true,
      "options": [
        "Standard_B1s",
        "Standard_B1ms",
        "Standard_B2s",
        "Standard_B2ms",
        "Standard_B4ms",
        "Standard_D2s_v3",
        "Standard_D4s_v3",
        "Standard_D8s_v3",
        "Standard_F2s_v2",
        "Standard_F4s_v2",
        "Standard_E2s_v3",
        "Standard_E4s_v3"
      ],
      "default": "Standard_D2s_v3"
    },
    {
      "name": "admin_username",
      "label": "Admin Username",
      "type": "string",
      "required": true,
      "placeholder": "azureuser",
      "default": "azureuser"
    },
    {
      "name": "network_interface_ids",
      "label": "Network Interface IDs",
      "type": "list",
      "required": true,
      "placeholder": "/subscriptions/.../networkInterfaces/my-nic",
      "description": "Resource IDs of network interfaces (one per line)"
    },
    {
      "name": "os_disk_caching",
      "label": "OS Disk Caching",
      "type": "select",
      "required": false,
      "options": [
        "None",
        "ReadOnly",
        "ReadWrite"
      ],
      "default": "ReadWrite",
      "advanced": true
    },
    {
      "name": "os_disk_storage_account_type",
      "label": "OS Disk Storage Type",
      "type": "select",
      "required": false,
      "options": [
        "Standard_LRS",
        "StandardSSD_LRS",
        "Premium_LRS",
        "UltraSSD_LRS"
      ],
      "default": "StandardSSD_LRS",
      "advanced": true
    },
    {
      "name": "source_image_publisher",
      "label": "Image Publisher",
      "type": "select",
      "required": false,
      "options": [
        "Canonical",
        "RedHat",
        "Debian",
        "OpenLogic",
        "SUSE"
      ],
      "default": "Canonical",
      "advanced": true
    },
    {
      "name": "source_image_offer",
      "label": "Image Offer",
      "type": "string",
      "required": false,
      "placeholder": "0001-com-ubuntu-server-jammy",
      "default": "0001-com-ubuntu-server-jammy",
      "advanced": true
    },
    {
      "name": "source_image_sku",
      "label": "Image SKU",
      "type": "string",
      "required": false,
      "placeholder": "22_04-lts-gen2",
      "default": "22_04-lts-gen2",
      "advanced": true
    },
    {
      "name": "source_image_version",
      "label": "Image Version",
      "type": "string",
      "required": false,
      "default": "latest",
      "advanced": true
    },
    {
      "name": "disable_password_authentication",
      "label": "Disable Password Auth",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "Use SSH key instead of password",
      "advanced": true
    }
  ],
  "common_inputs": {
    "region": false,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/azure-vm-{name}/main.tf",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/azure/virtual-machine?ref=main"
  }
}

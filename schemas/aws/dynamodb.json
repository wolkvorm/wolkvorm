{
  "id": "dynamodb",
  "name": "DynamoDB Table",
  "description": "Amazon DynamoDB NoSQL key-value database table",
  "provider": "aws",
  "icon": "dynamodb",
  "category": "database",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/aws/dynamodb?ref=main"
  },
  "inputs": [
    {
      "name": "name",
      "label": "Table Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app-table",
      "description": "Name of the DynamoDB table"
    },
    {
      "name": "billing_mode",
      "label": "Billing Mode",
      "type": "select",
      "default": "PAY_PER_REQUEST",
      "options": [
        "PAY_PER_REQUEST",
        "PROVISIONED"
      ],
      "description": "Billing mode (on-demand or provisioned)"
    },
    {
      "name": "hash_key",
      "label": "Partition Key",
      "type": "string",
      "required": true,
      "placeholder": "id",
      "description": "Attribute name for the partition key"
    },
    {
      "name": "range_key",
      "label": "Sort Key (optional)",
      "type": "string",
      "placeholder": "timestamp",
      "description": "Attribute name for the sort key"
    },
    {
      "name": "point_in_time_recovery_enabled",
      "label": "Point-in-Time Recovery",
      "type": "boolean",
      "default": true,
      "description": "Enable point-in-time recovery backups"
    },
    {
      "name": "deletion_protection_enabled",
      "label": "Deletion Protection",
      "type": "boolean",
      "default": false,
      "description": "Prevent accidental table deletion"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/dynamodb-{name}/main.tf"
}
{
  "id": "sns",
  "name": "SNS Topic",
  "description": "Amazon Simple Notification Service topic for pub/sub messaging",
  "provider": "aws",
  "icon": "sns",
  "category": "messaging",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/aws/sns?ref=main",
    "outputs": [
      "topic_arn",
      "topic_id"
    ]
  },
  "inputs": [
    {
      "name": "name",
      "label": "Topic Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app-notifications",
      "description": "Name of the SNS topic"
    },
    {
      "name": "display_name",
      "label": "Display Name",
      "type": "string",
      "placeholder": "My App Notifications",
      "description": "Display name for SMS subscriptions"
    },
    {
      "name": "fifo_topic",
      "label": "FIFO Topic",
      "type": "boolean",
      "default": false,
      "description": "Enable FIFO (first-in-first-out) delivery"
    },
    {
      "name": "kms_master_key_id",
      "label": "KMS Key ID (optional)",
      "type": "string",
      "placeholder": "alias/aws/sns",
      "description": "KMS key for server-side encryption"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/sns-{name}/main.tf"
}
{
  "id": "autoscaling",
  "name": "Auto Scaling Group",
  "description": "EC2 Auto Scaling Group for automatic capacity management",
  "provider": "aws",
  "icon": "autoscaling",
  "category": "compute",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/aws/autoscaling?ref=main",
    "outputs": [
      "autoscaling_group_arn",
      "autoscaling_group_id",
      "autoscaling_group_name"
    ]
  },
  "inputs": [
    {
      "name": "name",
      "label": "ASG Name",
      "type": "string",
      "required": true,
      "placeholder": "my-app-asg",
      "description": "Name of the Auto Scaling Group"
    },
    {
      "name": "instance_type",
      "label": "Instance Type",
      "type": "select",
      "default": "t3.micro",
      "options": [
        "t3.micro",
        "t3.small",
        "t3.medium",
        "t3.large",
        "m5.large",
        "m5.xlarge",
        "c5.large"
      ],
      "description": "EC2 instance type for the launch template"
    },
    {
      "name": "image_id",
      "label": "AMI ID",
      "type": "string",
      "required": true,
      "placeholder": "ami-0c55b159cbfafe1f0",
      "description": "AMI ID for the instances"
    },
    {
      "name": "min_size",
      "label": "Min Size",
      "type": "number",
      "default": 1,
      "description": "Minimum number of instances"
    },
    {
      "name": "max_size",
      "label": "Max Size",
      "type": "number",
      "default": 3,
      "description": "Maximum number of instances"
    },
    {
      "name": "desired_capacity",
      "label": "Desired Capacity",
      "type": "number",
      "default": 1,
      "description": "Desired number of instances"
    },
    {
      "name": "vpc_zone_identifier",
      "label": "Subnet IDs",
      "type": "string",
      "required": true,
      "placeholder": "subnet-abc123,subnet-def456",
      "description": "Comma-separated subnet IDs for the ASG"
    },
    {
      "name": "health_check_type",
      "label": "Health Check Type",
      "type": "select",
      "default": "EC2",
      "options": [
        "EC2",
        "ELB"
      ],
      "description": "Type of health check"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/asg-{name}/main.tf"
}
{
  "id": "apigateway",
  "name": "API Gateway",
  "description": "Amazon API Gateway v2 (HTTP/WebSocket API)",
  "provider": "aws",
  "icon": "apigateway",
  "category": "networking",
  "module": {
    "source": "git::https://github.com/wolkvorm/wolkvorm.git//modules/aws/apigateway?ref=main",
    "outputs": [
      "api_arn",
      "api_id",
      "api_endpoint"
    ]
  },
  "inputs": [
    {
      "name": "name",
      "label": "API Name",
      "type": "string",
      "required": true,
      "placeholder": "my-http-api",
      "description": "Name of the API Gateway"
    },
    {
      "name": "protocol_type",
      "label": "Protocol",
      "type": "select",
      "default": "HTTP",
      "options": [
        "HTTP",
        "WEBSOCKET"
      ],
      "description": "API protocol type"
    },
    {
      "name": "description",
      "label": "Description",
      "type": "string",
      "placeholder": "My HTTP API",
      "description": "Description of the API"
    }
  ],
  "common_inputs": {
    "region": true,
    "environment": true,
    "tags": true
  },
  "path_template": "infra/{env}/apigw-{name}/main.tf"
}